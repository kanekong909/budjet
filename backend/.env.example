# Copia este archivo como .env y rellena los valores
# En Railway, configura estas variables en el panel de Environment Variables

# Base de datos MySQL (Railway te da estos valores automáticamente)
DB_HOST=your-mysql-host.railway.app
DB_PORT=3306
DB_NAME=obra_gastos
DB_USER=root
DB_PASS=your-password

# JWT - pon una cadena larga y aleatoria
JWT_SECRET=cambia-esto-por-una-clave-muy-larga-y-secreta-123456

# Puerto (Railway lo asigna automáticamente)
PORT=3000

# URL del frontend (para CORS)
FRONTEND_URL=https://tu-usuario.github.io

# Cloudinary (opcional, para subir fotos de facturas)
# Crea cuenta gratis en cloudinary.com
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret
